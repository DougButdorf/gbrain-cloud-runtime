# Required for Day 1 runtime proof.
# Use the existing Supabase/Postgres connection string. Prefer the pooler URL
# for app/query traffic. Do not commit the real value.
GBRAIN_DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?sslmode=require

# Recommended when running migrations, queue/lock-heavy workers, or doctor checks
# that need a session-mode/direct path. Do not set until you have the correct
# Supabase session-pooler URL.
GBRAIN_DIRECT_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require

# Mirror this from the current local runtime if no direct/session pool is
# available for cloud Day 1. Leave unset when GBRAIN_DIRECT_DATABASE_URL is set.
GBRAIN_DISABLE_DIRECT_POOL=1
GBRAIN_PACE_MODE=balanced
GBRAIN_SYNC_STALL_ABORT_SECONDS=600

# Needed for embedding/query expansion flows that use OpenAI-backed models.
# If the brain is configured for ZeroEntropy/Voyage/etc., set that provider's
# key instead or alongside this one.
OPENAI_API_KEY=sk-REDACTED

# Current Doug GBRAIN DB model config uses DeepSeek for chat/reasoning and
# Gemini for utility/expansion. Keep these available in cloud if that config
# remains active. Add ANTHROPIC_API_KEY later when we intentionally route
# selected GBRAIN tasks to Anthropic API-backed models.
DEEPSEEK_API_KEY=redacted
GOOGLE_GENERATIVE_AI_API_KEY=redacted
# ANTHROPIC_API_KEY=redacted

# Optional model overrides. Leave unset for the brain's current config.
# GBRAIN_EMBEDDING_MODEL=openai:text-embedding-3-large
# GBRAIN_EMBEDDING_DIMENSIONS=1536
# GBRAIN_EXPANSION_MODEL=openai:gpt-4o-mini
# GBRAIN_CHAT_MODEL=openai:gpt-5.2

# HTTP runtime hardening.
GBRAIN_ADMIN_BOOTSTRAP_TOKEN=generate-at-least-32-url-safe-chars
GBRAIN_REQUIRE_ADMIN_TOKEN=1
GBRAIN_HTTP_TRUST_PROXY=1
GBRAIN_HTTP_CORS_ORIGIN=https://claude.ai,https://chatgpt.com,https://chat.openai.com
GBRAIN_PUBLIC_URL=https://gbrain-serve-test.up.railway.app
GBRAIN_INGEST_MAX_BYTES=1048576

# Railway should build from the nested Dockerfile. railway.toml carries the
# path, but setting this variable in Railway is an extra guard if deploy source
# detection ignores the toml.
RAILWAY_DOCKERFILE_PATH=infra/gbrain-cloud-runtime/Dockerfile

# Railway injects PORT automatically. Keep this only for local container runs.
PORT=8765
