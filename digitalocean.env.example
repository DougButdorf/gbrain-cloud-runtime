# DigitalOcean App Platform runtime variables for the no-cutover proof.
# Put real values only into DigitalOcean secrets or a private local shell.

GBRAIN_DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?sslmode=require
OPENAI_API_KEY=sk-REDACTED
DEEPSEEK_API_KEY=redacted
GOOGLE_GENERATIVE_AI_API_KEY=redacted
GBRAIN_ADMIN_BOOTSTRAP_TOKEN=generate-at-least-32-url-safe-chars

GBRAIN_REQUIRE_ADMIN_TOKEN=1
GBRAIN_DISABLE_DIRECT_POOL=1
GBRAIN_HTTP_TRUST_PROXY=1
GBRAIN_HTTP_CORS_ORIGIN=https://claude.ai,https://chatgpt.com,https://chat.openai.com
GBRAIN_INGEST_MAX_BYTES=1048576

# Set to the default DigitalOcean app URL after first deploy, then redeploy.
GBRAIN_PUBLIC_URL=https://gbrain-cloud-runtime-REPLACE.ondigitalocean.app
